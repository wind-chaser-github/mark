{
  "manifest_version": 3,
  "name": "智能书签管家 (AI Bookmark)",
  "version": "1.1",
  "description": "一键收藏网页并交给 AI 自动分类。",
  "permissions": ["activeTab", "tabs", "scripting", "bookmarks", "storage"],
  "host_permissions": ["http://localhost:3999/*", "<all_urls>"],
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "save-bookmark": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "MacCtrl+Shift+S"
      },
      "description": "Save current page as bookmark"
    }
  }
}
